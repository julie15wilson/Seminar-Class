kableExtra::row_spec(2, background = "#fddbc7") %>%  # Post-Dobbs
# Severely Restrictive
kableExtra::row_spec(3, background = "#f4a582") %>%
kableExtra::row_spec(4, background = "#f4a582") %>%
# Moderately Restrictive
kableExtra::row_spec(5, background = "#ffffbf") %>%
kableExtra::row_spec(6, background = "#ffffbf") %>%
# Moderately Permissive
kableExtra::row_spec(7, background = "#d1e5f0") %>%
kableExtra::row_spec(8, background = "#d1e5f0") %>%
# Permissive
kableExtra::row_spec(9,  background = "#92c5de") %>%
kableExtra::row_spec(10, background = "#92c5de") %>%
# Bold the Pre-Dobbs rows
kableExtra::row_spec(c(1, 3, 5, 7, 9),  bold = TRUE)
