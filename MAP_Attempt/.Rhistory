install.packages("pacman")
pacman::p_load(tidyverse, maps, sf, viridis)
library("pacman")
install.packages("tidyverse")
library("tidyverse")
install.packages("maps")
library("maps")
library(dplyr)
read.csv("Final_data.csv")
abort_pop <- read.csv("abort_pop.csv")
Main_US_States <- map_data("state")
glimpse(Main_US_States)
head(Main_US_States)
abort_pop <- abort_pop %>%
mutate(State= tolower(State, Month, abortions.per.1000.women.1544)
map_rates <- abort_pop %>%
mutate(State= tolower(State, Month, abortions.per.1000.women.1544)
map_rates <- abort_pop %>%
map_rates <- abort_pop %>%
select(State, Month, abortions.per.1000.women.1544)
map_rates<- abort_pop %>%
filter(Month == "4/1/2022") %>%
select(State, abortions.per.1000.women.1544) %>%
mutate(
State = tolower(State), abortions.per.1000.women.1544 = as.numeric(gsub(",","", abortions.per.1000.women.1544)))
state_labels <- Main_US_States %>%
group_by (region) %>%
summarize(
long= mean(long),
lat= mean(lat))
state_labels$abb <- state.abb[match(state_labels$region, tolower(state.name))]
map_df <-  Main_US_States %>%
left_join(map_rates, by = c("region" = "State"))
ggplot(map_df, aes(long, lat, group= group, fill = abortions.per.1000.women.1544)) + geom_polygon(color = "white", linewidth = 0.2) +
geom_text(data= state_labels,
aes(x= long, y= lat, label = abb), inherit.aes = FALSE, size = 3, color = "white")
coord_fixed(1.3) +
scale_fill_gradient(low= "lightblue", high = "darkblue", na.value = "gray90")+
labs(
title = "Abortion Rate per 1000 Women (April 2022)",
fill = "Total Abortions") +
theme_void()
